# ============================================================================
# 梦枕项目 - 环境变量配置模板
# 使用方法：复制此文件为 .env.local，填写实际值
# 部署到 Vercel/其他平台时，在对应平台的环境变量管理处设置
# ============================================================================

# ---- Supabase 数据库配置（必需）----
# 在 Supabase 控制台的 Project Settings → API 中获取
# https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Next.js 配置（可选）----
# 生产环境部署时设为 production
NODE_ENV=production

# ---- 说明 ----
# 缺少 SUPABASE_URL 或 SUPABASE_SERVICE_ROLE_KEY 时，所有 API 路由
# （登录/注册/音频上传等）将返回："数据库服务未配置，请联系管理员"
#
# SUPABASE_SERVICE_ROLE_KEY 是服务端密钥，有 bypass RLS 的权限
# 只在服务端代码中使用，不要暴露给客户端
