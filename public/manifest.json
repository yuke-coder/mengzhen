{
  "name": "梦枕 - 睡眠音频播放器",
  "short_name": "梦枕",
  "description": "专为浅眠人群设计的睡眠音频播放器，支持自定义定时、淡入淡出、全自动运行",
  "start_url": "/settings",
  "display": "standalone",
  "background_color": "#050510",
  "theme_color": "#00d4aa",
  "orientation": "portrait",
  "scope": "/",
  "icons": [
    {
      "src": "/favicon.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/favicon.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "categories": ["health", "lifestyle", "utilities"],
  "lang": "zh-CN",
  "dir": "ltr",
  "prefer_related_applications": false,
  "shortcuts": [
    {
      "name": "定时播放",
      "short_name": "定时",
      "description": "设置定时音频播放",
      "url": "/settings",
      "icons": [{ "src": "/favicon.png", "sizes": "512x512" }]
    },
    {
      "name": "音频管理",
      "short_name": "音频",
      "description": "管理音频文件和播放列表",
      "url": "/settings?tab=audio",
      "icons": [{ "src": "/favicon.png", "sizes": "512x512" }]
    }
  ],
  "share_target": {
    "action": "/settings",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "files": [
        {
          "name": "audio",
          "accept": ["audio/*", ".mp3", ".wav", ".ogg", ".m4a", ".flac", ".aac"]
        }
      ]
    }
  }
}
